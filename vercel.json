{
  "version": 2,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(self), geolocation=()"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com https://umami.noxamusic.com; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data: https: blob:; media-src 'self' blob: https://azura.typicalmedia.net https://*.typicalmedia.net; connect-src 'self' https://azura.typicalmedia.net https://api.typicalmedia.net https://discordlookup.mesavirep.xyz https://japi.rest https://cdn.discordapp.com https://umami.noxamusic.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
        }
      ]
    },
    {
      "source": "/Resources/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, s-maxage=31536000, immutable"
        }
      ]
    },
    {
      "source": "/Public/Resources/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, s-maxage=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)\\.(webp|png|jpg|jpeg|gif|svg|ico|avif|woff|woff2|ttf|otf|eot)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, s-maxage=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)\\.(css|js)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, s-maxage=31536000, stale-while-revalidate=604800"
        }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, s-maxage=300, stale-while-revalidate=86400, must-revalidate"
        }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/about",
      "destination": "/Public/about.html"
    },
    {
      "source": "/archives",
      "destination": "/Public/archives.html"
    },
    {
      "source": "/programs",
      "destination": "/Public/programs.html"
    },
    {
      "source": "/talk-to-tina",
      "destination": "/Public/talk-to-tina.html"
    },
    {
      "source": "/beyond-the-veil",
      "destination": "/Public/beyond-the-veil.html"
    },
    {
      "source": "/blog",
      "destination": "/Public/blog.html"
    },
    {
      "source": "/blog/wsqk-stranger-things-radio",
      "destination": "/Public/blog/wsqk-stranger-things-radio.html"
    },
    {
      "source": "/blog/80s-songs-radio-station",
      "destination": "/Public/blog/80s-songs-radio-station.html"
    },
    {
      "source": "/blog/best-online-radio-station",
      "destination": "/Public/blog/best-online-radio-station.html"
    },
    {
      "source": "/blog/listen-80s-music-free",
      "destination": "/Public/blog/listen-80s-music-free.html"
    },
    {
      "source": "/playlist",
      "destination": "/Public/playlist.html"
    },
    {
      "source": "/live",
      "destination": "/Public/live.html"
    },
    {
      "source": "/",
      "destination": "/Public/index.html"
    },
    {
      "source": "/blog/:slug",
      "destination": "/Public/blog/:slug.html"
    },
    {
      "source": "/:path*",
      "destination": "/Public/:path*"
    }
  ]
}